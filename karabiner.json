{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          {
            "description": "Change caps lock to hyper key",
            "manipulators": [
              {
                "from": { "key_code": "caps_lock" },
                "to": [
                  {
                    "set_variable": {
                      "name": "hyper_pressed",
                      "value": 1
                    }
                  },
                  {
                    "key_code": "left_shift",
                    "modifiers": ["left_command", "left_control", "left_option"]
                  }
                ],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "hyper_pressed",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Hyper key app launcher shortcuts",
            "manipulators": [
              {
                "from": {
                  "key_code": "t",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
                "to": [{ "shell_command": "open -a \"Alacritty\"" }],
                "type": "basic"
              },
              {
                "from": {
                  "key_code": "v",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
