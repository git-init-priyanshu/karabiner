                },
                "to": [{ "shell_command": "open -a \"YouTube Music\"" }],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Hyper + C -> Next window of same application",
            "manipulators": [
              {
                "from": {
                  "key_code": "c",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
                "to": [
                  {
                    "key_code": "grave_accent_and_tilde",
                    "modifiers": ["command"]
                  }
                ],
                "type": "basic"
              }
            ]
          },
          {
            "description": "Hyper + X -> Previous window of same application",
            "manipulators": [
              {
                "from": {
                  "key_code": "x",
                  "modifiers": {
                    "mandatory": ["command", "control", "option", "shift"]
                  }
                },
                "to": [
